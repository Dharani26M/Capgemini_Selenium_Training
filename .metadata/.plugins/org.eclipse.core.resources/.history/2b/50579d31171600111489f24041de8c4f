package selenium_webdriver_interrogation_method;

import java.time.Duration;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class TitleVerification {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		WebDriver driver=new ChromeDriver();
		driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(16));
		try {
		driver.get("https://demowebshop.tricentis.com/");
		driver.manage().window().maximize();
		String Expected_Title="Dem1 Web Shop";
		String Actual_title=driver.getTitle();
		if(Actual_title.equals(Expected_Title)) {
			System.out.println("Navigation is successfull");
		}
		else {
            throw new Exception("Title Mismatch! Expected [" + Expected_Title + "] but found [" + Actual_title + "]");
        }
		}catch(Exception e) {
			System.out.println("failed");
		}
	}

}
