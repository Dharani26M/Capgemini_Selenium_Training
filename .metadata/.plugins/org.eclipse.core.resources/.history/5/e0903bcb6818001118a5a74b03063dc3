package selenium_popups_methods;

import java.time.Duration;

import org.openqa.selenium.By;
import org.openqa.selenium.Keys;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WindowType;
import org.openqa.selenium.chrome.ChromeDriver;

public class Popups_NewWindow {

	public static void main(String[] args) throws InterruptedException {
		// TODO Auto-generated method stub
		WebDriver driver =new ChromeDriver();
		driver.manage().window().maximize();
		driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(18));
		driver.get("https:google.com");
		driver.switchTo().newWindow(WindowType.WINDOW).get("https:youtube.com");
		System.out.println(driver.getTitle());
		driver.findElement(By.xpath("//input[@name='search_query']")).sendKeys("spirit of esctasy",Keys.ENTER);
		Thread.sleep(2000);
		driver.quit();
	}

}
